# ============================================================================
# SERVER-SIDE ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# For backend/server-side operations only
# NEVER expose these to the client
# ============================================================================

# VAPID Private Key (NEVER share this)
# Generate: node scripts/generate-vapid.js
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_SUBJECT=mailto:admin@example.com

# Firebase Admin SDK Key (NEVER expose this)
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_ADMIN_SDK_KEY=your_firebase_admin_sdk_json

# Supabase Server Key (NEVER expose this to client)
SUPABASE_API_KEY=your_supabase_server_api_key
SUPABASE_PROJECT_ID=your_supabase_project_id
SUPABASE_URL=https://your_project.supabase.co

# Database Connection Strings
DATABASE_URL=postgresql://user:password@host:port/database

# OneSignal API Key (if using OneSignal)
ONESIGNAL_API_KEY=your_onesignal_api_key
ONESIGNAL_APP_ID=your_onesignal_app_id

# JWT Secret for custom authentication
JWT_SECRET=your_strong_random_secret_here_min_32_chars

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com
