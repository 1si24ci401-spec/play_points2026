{
  "version": "1.4.0",
  "exclude": {
    "files": [
      "^.*/node_modules/.*",
      "^.*/dist/.*",
      "^\\.git/.*",
      "^\\.github/.*",
      "^.*\\.lock$",
      "^.*\\.log$"
    ],
    "paths": [
      "node_modules",
      "dist",
      ".git",
      ".github"
    ]
  },
  "rules": [
    {
      "type": "regex",
      "pattern": "(?i)(password|passwd|pwd|secret|token|api[_-]?key|auth|private[_-]?key)\\s*[:=]\\s*[^\\s]+",
      "message": "Potential secret/credential detected"
    },
    {
      "type": "regex",
      "pattern": "(?i)(firebase[_-]?(?:api[_-]?)?key|supabase[_-]?(?:anon|service[_-]?role)[_-]?key)\\s*[:=]",
      "message": "Potential Firebase/Supabase credential detected"
    },
    {
      "type": "regex",
      "pattern": "(?i)(vapid[_-]?(?:private|secret)[_-]?key)\\s*[:=]",
      "message": "Potential VAPID private key detected"
    },
    {
      "type": "regex",
      "pattern": "(?i)(jwt[_-]?secret|access[_-]?token|refresh[_-]?token)\\s*[:=]",
      "message": "Potential JWT/token secret detected"
    },
    {
      "type": "regex",
      "pattern": "(?i)(database[_-]?(?:url|uri|password|connection[_-]?string))\\s*[:=]",
      "message": "Potential database credential detected"
    },
    {
      "type": "entropy",
      "threshold": 3.5,
      "message": "High entropy string detected (potential secret)"
    }
  ]
}
